# 生产环境配置
NEXT_PUBLIC_ENV=production
# 请将此值替换为你的生产站点域名（例如：https://app.your-domain.com）
NEXT_PUBLIC_APP_URL=https://your-production-domain.example.com

# 应用配置
NEXT_PUBLIC_APP_NAME="i love delay"

# zh en
NEXT_PUBLIC_DEFAULT_LOCALE=zh

# 数据库（生产）
# 推荐 DB 名称：i_love_delay
# 示例：postgres://user:password@db-host:5432/i_love_delay
DATABASE_URL=

# 若需 SSL：
# PGSSLMODE=require